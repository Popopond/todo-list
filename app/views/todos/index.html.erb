<div class="max-w-3xl mx-auto mt-8 p-4" data-controller="modal">
  <p style="color: green"><%= notice %></p>

  <div class="flex items-center justify-between mb-5">
    <h1 class="text-5xl font-bold text-slate-800">My Tasks 📝</h1>
    <button type="button" data-action="modal#open" class="bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold py-2 px-4 rounded-lg">
      + New Task
    </button>
  </div>

  <dialog data-modal-target="dialog" data-action="click->modal#closeOnBackdrop" class="p-0 rounded-2xl w-[min(90vw,32rem)] max-w-lg m-auto backdrop:bg-slate-900/30">
    <div class="bg-white rounded-2xl p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-bold text-slate-800">Create New Task</h2>
        <button type="button" data-action="modal#close" class="text-slate-500 hover:text-slate-700 text-2xl leading-none">&times;</button>
      </div>

      <%= form_with model: Todo.new, url: todos_path do |form| %>
        <%= hidden_field_tag :return_to, todos_path %>

        <div class="mb-3">
          <%= form.label :title, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.text_field :title, class: "w-full rounded-lg border-slate-300 focus:border-blue-500 focus:ring-blue-500" %>
        </div>

        <div class="mb-5">
          <%= form.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= form.text_area :description, rows: 4, class: "w-full rounded-lg border-slate-300 focus:border-blue-500 focus:ring-blue-500" %>
        </div>

        <div class="flex justify-end gap-2">
          <button type="button" data-action="modal#close" class="border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-medium py-2 px-4 rounded-lg">
            Cancel
          </button>
          <%= form.submit "Create Task", class: "bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold py-2 px-4 rounded-lg" %>
        </div>
      <% end %>
    </div>
  </dialog>

  <div id="todos" class="space-y-3">
    <% @todos.each do |todo| %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm px-4 py-3 flex items-center justify-between gap-4">
        <div class="flex items-start gap-3 min-w-0 flex-1">
          <%= form_with model: todo, class: "pt-1" do |form| %>
            <%= hidden_field_tag :return_to, todos_path %>
            <%= form.checkbox :completed,
              class: "h-5 w-5 rounded border-slate-300 text-slate-500 focus:ring-slate-400",
              onchange: "this.form.requestSubmit()" %>
          <% end %>

          <div class="min-w-0">
            <h2 class="text-3xl font-semibold truncate <%= todo.completed ? 'line-through text-slate-400' : 'text-slate-900' %>">
              <%= link_to todo.title, todo_path(todo), data: { turbo_prefetch: false }, class: "hover:underline" %>
            </h2>
            <p class="text-2xl text-slate-700 truncate <%= todo.completed ? 'text-slate-400' : '' %>">
              <%= todo.description %>
            </p>
          </div>
        </div>

        <p class="text-xs text-slate-500 whitespace-nowrap">
          Updated: <%= todo.updated_at.strftime("%B %-d, %Y at %-I:%M %p") %>
        </p>

        <div class="flex items-center gap-2 whitespace-nowrap">
          <%= link_to "Edit", edit_todo_path(todo), data: { turbo_prefetch: false }, class: "border border-slate-400 text-slate-600 hover:bg-slate-50 text-sm font-medium py-1 px-3 rounded-lg" %>
          <%= button_to "Delete", todo, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "border border-red-400 text-red-600 hover:bg-red-50 text-sm font-medium py-1 px-3 rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>