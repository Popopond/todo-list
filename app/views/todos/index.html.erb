<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">
        <h4 class="mb-0">My Todos
          <span class="badge"><%= @todos.count %></span>
        </h4>
        <a href="<%= new_todo_path %>" class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          New Todo
        </a>
      </div>
      <% if @todos.empty? %>
        <div class="text-center py-5 text-muted">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          <p class="mt-2">No todos yet. Create one!</p>
        </div>
      <% else %>
        <ul class="list-group">
          <% @todos.each do |todo| %>
            <li class="list-group-item">
              <%= button_to toggle_todo_path(todo), method: :patch, class: "todo-toggle" do %>
                <% if todo.completed %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <% else %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                <% end %>
              <% end %>
              <span class="flex-grow-1 <%= 'text-complete' if todo.completed %>">
                <%= todo.title %>
              </span>
              <div class="d-flex gap-1">
                <%= link_to edit_todo_path(todo), class: "btn btn-outline-secondary btn-sm" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                <% end %>
                <%= button_to todo_path(todo), method: :delete, class: "btn btn-outline-danger btn-sm",
                    data: { turbo_confirm: "Delete this todo?" } do %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
        <div class="card-footer">
          <%= @todos.count(&:completed) %> of <%= @todos.count %> completed
        </div>
      <% end %>
    </div>
  </div>
</div>
