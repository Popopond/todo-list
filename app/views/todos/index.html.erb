<div class="max-w-3xl mx-auto mt-10 p-6 bg-white shadow-lg rounded-lg">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">My Todo List 📝</h1>
    <%= link_to "New Todo", new_todo_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg transition" %>
  </div>

  <div id="todos" class="space-y-4">
    <% @todos.each do |todo| %>
      <div class="flex items-center justify-between p-4 border-b border-gray-100 hover:bg-gray-50 rounded-md transition">
        <div>
          <h2 class="text-xl font-semibold <%= todo.completed ? 'line-through text-gray-400' : 'text-gray-700' %>">
            <%= todo.title %>
          </h2>
          <p class="text-gray-500 text-sm"><%= todo.description %></p>
        </div>
        
        <div class="flex space-x-2">
          <%= link_to "Edit", edit_todo_path(todo), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
          <%= button_to "Delete", todo, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-500 hover:text-red-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>