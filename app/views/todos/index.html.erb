<div class="max-w-3xl mx-auto mt-8 p-4">
  <p style="color: green"><%= notice %></p>

  <div class="flex items-center justify-between mb-5">
    <h1 class="text-5xl font-bold text-slate-800">My Tasks 📝</h1>
    <%= link_to "+ New Task", new_todo_path, class: "bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold py-2 px-4 rounded-lg" %>
  </div>

  <div id="todos" class="space-y-3">
    <% @todos.each do |todo| %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm px-4 py-3 flex items-center justify-between gap-4">
        <div class="flex items-start gap-3 min-w-0 flex-1">
          <%= form_with model: todo, class: "pt-1" do |form| %>
            <%= form.checkbox :completed,
              class: "h-5 w-5 rounded border-slate-300 text-slate-500 focus:ring-slate-400",
              onchange: "this.form.requestSubmit()" %>
          <% end %>

          <div class="min-w-0">
            <h2 class="text-3xl font-semibold truncate <%= todo.completed ? 'line-through text-slate-400' : 'text-slate-900' %>">
              <%= link_to todo.title, todo_path(todo), class: "hover:underline" %>
            </h2>
            <p class="text-2xl text-slate-700 truncate <%= todo.completed ? 'text-slate-400' : '' %>">
              <%= todo.description %>
            </p>
          </div>
        </div>

        <p class="text-xs text-slate-500 whitespace-nowrap">
          Updated: <%= todo.updated_at.strftime("%B %-d, %Y at %-I:%M %p") %>
        </p>

        <div class="flex items-center gap-2 whitespace-nowrap">
          <%= link_to "Edit", edit_todo_path(todo), class: "border border-slate-400 text-slate-600 hover:bg-slate-50 text-sm font-medium py-1 px-3 rounded-lg" %>
          <%= button_to "Delete", todo, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "border border-red-400 text-red-600 hover:bg-red-50 text-sm font-medium py-1 px-3 rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>