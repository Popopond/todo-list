<%= form_with(model: todo, class: "needs-validation") do |form| %>
  <% if todo.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(todo.errors.count, "error") %> prohibited this todo from being saved:</h6>
      <ul class="mb-0">
        <% todo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label fw-semibold" %>
    <%= form.text_field :title, class: "form-control", placeholder: "What needs to be done?" %>
  </div>

  <div class="mb-3 form-check">
    <%= form.check_box :completed, class: "form-check-input" %>
    <%= form.label :completed, "Mark as completed", class: "form-check-label" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", todos_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
